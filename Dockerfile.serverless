FROM ghcr.io/pealmeida/moa-v3-finetuning:latest

WORKDIR /workspace

RUN /opt/venv/bin/pip install --no-cache-dir --break-system-packages scikit-learn || /opt/venv/bin/pip install --no-cache-dir scikit-learn

COPY handler.py /workspace/handler.py

COPY entrypoint.sh /workspace/entrypoint.sh
RUN chmod +x /workspace/entrypoint.sh
